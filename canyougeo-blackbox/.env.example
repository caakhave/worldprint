CGY_TARGET=test
CGY_BASE_URL=

CGY_FREE_EMAIL=
CGY_FREE_PASSWORD=
CGY_PRO_EMAIL=
CGY_PRO_PASSWORD=

# Native Maestro auth persistence flows reuse the Free pair first, then Pro if
# Free is absent. Keep these values local; the runner injects MAESTRO_* env vars
# without placing secrets in flow YAML or command arguments.

# Optional live checkout-open smoke. This must be explicitly enabled and must use
# a signed-in Free test account. The test stops when Stripe Checkout opens.
CGY_ENABLE_CHECKOUT_SMOKE=0
CGY_CHECKOUT_EMAIL=
CGY_CHECKOUT_PASSWORD=
CGY_CHECKOUT_PLAN=monthly

# Optional signup analytics smoke. May create a test account and may send the
# normal account confirmation email for that environment.
CGY_ENABLE_SIGNUP_ANALYTICS_SMOKE=0
CGY_SIGNUP_ANALYTICS_EMAIL=
CGY_SIGNUP_ANALYTICS_EMAIL_BASE=
CGY_SIGNUP_ANALYTICS_PASSWORD=

CGY_TEST_EMAIL_ALIAS=
CGY_RUN_EMAIL_LIVE=0

# Optional: required only when running against an Access-protected test host.
# These values are Cloudflare Access service-token credentials. Never commit real values.
CGY_CF_ACCESS_CLIENT_ID=
CGY_CF_ACCESS_CLIENT_SECRET=
