# Can You Geo / WORLDPRINT environment template
# Copy this file to .env.local for local development. Never commit .env.local or real secret values.

# ---------------------------------------------------------------------------
# Local development
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL should match the origin that starts email sign-in.
# For `pnpm dev`, use http://localhost:3000.
# For `pnpm static:preview`, use http://localhost:3001.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_NO_INDEX=true
# Must be the Supabase project root URL only.
# Correct: https://jquebthneczqdxagagof.supabase.co
# Wrong:   https://jquebthneczqdxagagof.supabase.co/rest/v1
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
# Keep disabled unless you are intentionally running Stripe test-mode QA.
# Supported values: disabled, test, live.
# Current code enables checkout only for "test"; "live" is parsed but remains disabled
# until a future live billing implementation explicitly changes the app and QA plan.
NEXT_PUBLIC_BILLING_MODE=disabled
# Analytics is opt-in and production-only. Leave disabled locally and on staging.
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ---------------------------------------------------------------------------
# Cloudflare Pages preview
# ---------------------------------------------------------------------------
# Set these in the Cloudflare Pages preview environment, not in committed files.
# If preview sign-in is tested, the matching /auth/callback origin must be allowed
# in Supabase Auth Redirect URLs.
# NEXT_PUBLIC_SITE_URL=https://test.canyougeo.com
# NEXT_PUBLIC_NO_INDEX=true
# NEXT_PUBLIC_SUPABASE_URL must be the project root, not a REST/Auth endpoint path.
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
# Keep preview disabled unless this deploy is an intentional Stripe test QA window.
# NEXT_PUBLIC_BILLING_MODE=disabled
# Keep preview/staging analytics disabled. test.canyougeo.com is noindexed and
# the app will not load analytics there even if an ID is present.
# NEXT_PUBLIC_ANALYTICS_ENABLED=false
# NEXT_PUBLIC_GTM_ID=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ---------------------------------------------------------------------------
# Cloudflare Pages production
# ---------------------------------------------------------------------------
# Set these in the Cloudflare Pages production environment.
# NEXT_PUBLIC_SITE_URL=https://canyougeo.com
# NEXT_PUBLIC_NO_INDEX=false
# NEXT_PUBLIC_SUPABASE_URL must be the project root, not a REST/Auth endpoint path.
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
# Production default must stay disabled outside a planned billing QA or launch.
# NEXT_PUBLIC_BILLING_MODE=disabled
# Enable analytics only after Google Tag Manager or GA4 is configured for the
# production property. GTM is preferred when both IDs are set.
# NEXT_PUBLIC_ANALYTICS_ENABLED=false
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ---------------------------------------------------------------------------
# Supabase Edge Function env/secrets only
# ---------------------------------------------------------------------------
# These belong in trusted Supabase Edge Function settings or local function env,
# never in browser code or Cloudflare Pages public env.
# Hosted Supabase functions expose SUPABASE_* platform values automatically.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=<supabase-anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
# STRIPE_SECRET_KEY=<stripe-secret-key>
# STRIPE_WEBHOOK_SECRET=<stripe-webhook-signing-secret>
# STRIPE_PRO_MONTHLY_PRICE_ID=price_<monthly>
# STRIPE_PRO_YEARLY_PRICE_ID=price_<yearly>
# STRIPE_PRO_PRICE_ID=price_<legacy-fallback>
# NEXT_PUBLIC_SITE_URL=https://canyougeo.com

# ---------------------------------------------------------------------------
# Supabase Auth custom SMTP through Resend
# ---------------------------------------------------------------------------
# These are dashboard/operator values. The app does not read them directly.
# Configure them in Supabase Dashboard -> Authentication -> SMTP.
# RESEND_API_KEY=<resend-api-key>
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=<resend-api-key>
# SMTP_FROM="Can You Geo <auth@canyougeo.com>"
