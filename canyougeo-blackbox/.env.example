CGY_TARGET=test
CGY_BASE_URL=

CGY_FREE_EMAIL=
CGY_FREE_PASSWORD=
CGY_PRO_EMAIL=
CGY_PRO_PASSWORD=

# Optional production-auth smoke uses separate production-only variables. These
# are never used by the normal production-safe command.
CGY_PROD_FREE_EMAIL=
CGY_PROD_FREE_PASSWORD=
CGY_PROD_PRO_EMAIL=
CGY_PROD_PRO_PASSWORD=

# Native Maestro auth and billing-discovery flows use production-hosted app
# accounts only. They never fall back to CGY_FREE_*, CGY_PRO_*, or CGY_PROD_*.
# Keep these values local; the runner injects MAESTRO_* env vars without placing
# secrets in flow YAML, command arguments, screenshots, or debug artifacts.
CGY_NATIVE_FREE_EMAIL=
CGY_NATIVE_FREE_PASSWORD=
CGY_NATIVE_PRO_EMAIL=
CGY_NATIVE_PRO_PASSWORD=

# Optional device selection. If absent, Android resolves from CGY_ANDROID_DEVICE,
# ANDROID_SERIAL, or connected adb devices; iOS resolves exactly one booted
# simulator through simctl.
CGY_ANDROID_DEVICE=
CGY_IOS_SIMULATOR_UDID=

# Optional live checkout-open smoke. This must be explicitly enabled and must use
# a signed-in Free test account. The test stops when Stripe Checkout opens.
CGY_ENABLE_CHECKOUT_SMOKE=0
CGY_CHECKOUT_EMAIL=
CGY_CHECKOUT_PASSWORD=
CGY_CHECKOUT_PLAN=monthly

# Optional signup analytics smoke. May create a test account and may send the
# normal account confirmation email for that environment.
CGY_ENABLE_SIGNUP_ANALYTICS_SMOKE=0
CGY_SIGNUP_ANALYTICS_EMAIL=
CGY_SIGNUP_ANALYTICS_EMAIL_BASE=
CGY_SIGNUP_ANALYTICS_PASSWORD=

CGY_TEST_EMAIL_ALIAS=
CGY_RUN_EMAIL_LIVE=0

# Optional: required only when running against an Access-protected test host.
# These values are Cloudflare Access service-token credentials. Never commit real values.
CGY_CF_ACCESS_CLIENT_ID=
CGY_CF_ACCESS_CLIENT_SECRET=
